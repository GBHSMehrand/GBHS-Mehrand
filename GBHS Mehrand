<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GBHS Mehrand Complete Online System</title>

<!-- Firebase -->
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js"></script>

<style>
body{font-family:Arial;margin:0;background:#eef2f3}
header{background:#006400;color:white;text-align:center;padding:15px}
section{padding:20px;border-bottom:1px solid #ccc}
input,select{width:100%;padding:10px;margin:5px 0}
button{padding:10px;background:#006400;color:white;border:none;margin:3px;cursor:pointer}
.card{background:#f4f4f4;padding:10px;margin:10px 0;border-radius:5px}
.hidden{display:none}
</style>
</head>
<body>

<header>
<h2>GBHS Mehrand Complete Online School System</h2>
</header>

<section>
<h3>Login Panel</h3>
<select id="role">
<option value="admin">Admin</option>
<option value="teacher">Teacher</option>
<option value="student">Student</option>
</select>
<input type="password" id="pass" placeholder="Enter Password / Roll Number">
<button onclick="login()">Login</button>
</section>

<section id="adminPanel" class="hidden">
<h3>Admin / Teacher Panel</h3>

<h4>Admission</h4>
<input id="name" placeholder="Student Name">
<input id="roll" placeholder="Roll Number">
<select id="class">
<option>Nursery</option><option>KG</option>
<option>Class 1</option><option>Class 2</option><option>Class 3</option>
<option>Class 4</option><option>Class 5</option>
<option>Class 6</option><option>Class 7</option>
<option>Class 8</option><option>Class 9</option>
<option>Class 10</option>
</select>
<button onclick="addStudent()">Submit Admission</button>

<h4>Manage Students</h4>
<div id="studentList"></div>

<h4>Fee Management</h4>
<input id="feeRoll" placeholder="Roll Number">
<input id="feeAmount" placeholder="Fee Amount">
<button onclick="addFee()">Add/Update Fee</button>
<p id="feeStatus"></p>

<h4>Attendance</h4>
<input id="attRoll" placeholder="Roll Number">
<select id="attStatus">
<option>Present</option>
<option>Absent</option>
</select>
<button onclick="markAttendance()">Mark Attendance</button>

<h4>Generate ID Card</h4>
<input id="idRoll" placeholder="Roll Number">
<button onclick="generateID()">Generate ID</button>
<div id="idCard" style="border:1px solid #000;padding:10px;margin-top:10px"></div>
</section>

<section id="studentPanel" class="hidden">
<h3>Student Panel</h3>
<p id="studentData"></p>
<button onclick="printResult()">Download Result PDF</button>
</section>

<section id="checkResult">
<h3>Check Result by Roll Number</h3>
<input id="searchRoll" placeholder="Enter Roll Number">
<button onclick="getResult()">Check</button>
<p id="result"></p>
</section>

<!-- Firebase Config -->
<script>
const firebaseConfig = {
  apiKey: "YOUR_API_KEY",
  authDomain: "YOUR_PROJECT.firebaseapp.com",
  projectId: "YOUR_PROJECT",
};
firebase.initializeApp(firebaseConfig);
const db = firebase.firestore();

// Default passwords
const adminPass = "admin123";
const teacherPass = "teacher123";

// Login system
function login(){
  const role=document.getElementById("role").value;
  const pass=document.getElementById("pass").value;
  if(role=="admin" && pass==adminPass){
    document.getElementById("adminPanel").classList.remove("hidden");
    loadStudents();
  }
  else if(role=="teacher" && pass==teacherPass){
    document.getElementById("adminPanel").classList.remove("hidden");
    loadStudents();
    alert("Teacher login");
  }
  else if(role=="student"){
    const roll=pass;
    db.collection("students").where("roll","==",roll)
    .get().then(snap=>{
      snap.forEach(doc=>{
        const d=doc.data();
        document.getElementById("studentPanel").classList.remove("hidden");
        document.getElementById("studentData").innerHTML=
        `Welcome ${d.name} | Class: ${d.class} | Marks: ${d.marks}`;
      });
    });
  } else alert("Wrong credentials");
}

// Admission
function addStudent(){
  const name=document.getElementById("name").value;
  const roll=document.getElementById("roll").value;
  const cls=document.getElementById("class").value;
  db.collection("students").add({name, roll, class:cls, marks:0});
  alert("Student added successfully!");
  loadStudents();
}

// Load students for admin/teacher
function loadStudents(){
  db.collection("students").get().then(snap=>{
    let html="";
    snap.forEach(doc=>{
      const d=doc.data();
      html+=`<div class='card'>
        ${d.name} | ${d.roll} | Class: ${d.class} | Marks: ${d.marks}<br>
        <input placeholder='New Marks' id='m${doc.id}'>
        <button onclick="updateMarks('${doc.id}')">Update Marks</button>
        <button onclick="deleteStudent('${doc.id}')">Delete</button>
      </div>`;
    });
    document.getElementById("studentList").innerHTML=html;
  });
}

function updateMarks(id){
  const val=document.getElementById("m"+id).value;
  db.collection("students").doc(id).update({marks:val});
  alert("Marks updated");
  loadStudents();
}

function deleteStudent(id){
  db.collection("students").doc(id).delete();
  alert("Deleted");
  loadStudents();
}

// Fee
function addFee(){
  const roll=document.getElementById("feeRoll").value;
  const fee=document.getElementById("feeAmount").value;
  db.collection("students").where("roll","==",roll)
  .get().then(snap=>{
    snap.forEach(doc=>{
      db.collection("students").doc(doc.id).update({fee});
      document.getElementById("feeStatus").innerText="Fee updated";
    });
  });
}

// Attendance
function markAttendance(){
  const roll=document.getElementById("attRoll").value;
  const status=document.getElementById("attStatus").value;
  db.collection("attendance").add({roll,status,date:new Date().toLocaleDateString()});
  alert("Attendance marked");
}

// Generate ID
function generateID(){
  const roll=document.getElementById("idRoll").value;
  db.collection("students").where("roll","==",roll)
  .get().then(snap=>{
    snap.forEach(doc=>{
      const d=doc.data();
      document.getElementById("idCard").innerHTML=
        `<h3>GBHS Mehrand</h3>
        Name: ${d.name}<br>Roll: ${d.roll}<br>Class: ${d.class}`;
    });
  });
}

// Student result check
function getResult(){
  const roll=document.getElementById("searchRoll").value;
  db.collection("students").where("roll","==",roll)
  .get().then(snap=>{
    snap.forEach(doc=>{
      const d=doc.data();
      document.getElementById("result").innerHTML=
      `Name: ${d.name} | Class: ${d.class} | Marks: ${d.marks}`;
    });
  });
}

// Print PDF
function printResult(){
  window.print();
}
</script>

</body>
</html>
